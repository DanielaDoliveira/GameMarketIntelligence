<div class="">
    
</div>
@code {
    [Parameter, EditorRequired] public string Heading { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; } 
    [Parameter] public RenderFragment? Icon {get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter]public FeedbackStateVariant Variant { get; set; } = FeedbackStateVariant.Default;

    private string? Role => Variant == FeedbackStateVariant.Error ? "alert" : null;
    
    private string CssClass =>
        Variant switch
        {
            FeedbackStateVariant.Default => "feedback-state",

            FeedbackStateVariant.Error => "feedback-state feedback-state--error",

            _ => throw new ArgumentOutOfRangeException(nameof(Variant), Variant, "Unsupported feedback-state variant.")
        };

}