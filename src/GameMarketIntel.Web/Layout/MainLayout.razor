@inherits LayoutComponentBase

<div class="@ShellCssClass"
     @onkeydown="HandleKeyDown">

    <header class="application-header">
        <div class="application-header__left">
            <button type="button"
                    class="icon-button application-header__menu-button"
                    aria-label="@MenuButtonLabel"
                    aria-expanded="@IsNavigationExpanded"
                    aria-controls="application-navigation"
                    @onclick="ToggleNavigation">
                @if (IsMobileDrawerOpen)
                {
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6 6 18 18M18 6 6 18" />
                    </svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M4 7H20M4 12H20M4 17H20" />
                    </svg>
                }
            </button>

            <a class="product-identity"
               href="/"
               aria-label="GameMarketIntel home">
                <span class="product-identity__mark"
                      aria-hidden="true">
                    GM
                </span>

                <span class="product-identity__name">
                    GameMarketIntel
                </span>
            </a>
        </div>

        <div class="application-header__center">
            <label class="visually-hidden"
                   for="comparable-games-search">
                Search comparable games
            </label>

            <div class="header-search header-search--disabled">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="11"
                            cy="11"
                            r="6.5" />
                    <path d="M16 16 21 21" />
                </svg>

                <input id="comparable-games-search"
                       type="search"
                       placeholder="Search comparable games..."
                       aria-describedby="search-availability-message"
                       disabled />
            </div>

            <span id="search-availability-message"
                  class="visually-hidden">
                Search will become available on the Comparable Games page.
            </span>
        </div>

        <div class="application-header__right"
             aria-hidden="true">
        </div>
    </header>

    <aside id="application-navigation"
           class="application-sidebar"
           aria-label="Primary navigation">
        <NavMenu IsCompact="@IsDesktopSidebarCollapsed"
                 OnNavigate="CloseMobileDrawer" />
    </aside>

    <main class="application-main">
        <div class="application-content">
            @Body
        </div>

        <footer class="application-footer">
            <span>GameMarketIntel</span>

            <nav aria-label="Footer navigation">
                <a href="/">About</a>
                <a href="/sources">Data Sources</a>
                <a href="https://github.com/"
                   target="_blank"
                   rel="noopener noreferrer">
                    GitHub
                    <span class="visually-hidden">
                        opens in a new tab
                    </span>
                </a>
            </nav>
        </footer>
    </main>

    @if (IsMobileDrawerOpen)
    {
        <button type="button"
                class="navigation-overlay"
                aria-label="Close navigation"
                @onclick="CloseMobileDrawer">
        </button>
    }
</div>

@code {
    private bool IsDesktopSidebarCollapsed { get; set; }

    private bool IsMobileDrawerOpen { get; set; }

    private string ShellCssClass =>
        string.Join(
            " ",
            "application-shell",
            IsDesktopSidebarCollapsed
                ? "application-shell--sidebar-collapsed"
                : null,
            IsMobileDrawerOpen
                ? "application-shell--drawer-open"
                : null);

    private bool IsNavigationExpanded =>
        IsMobileDrawerOpen || !IsDesktopSidebarCollapsed;

    private string MenuButtonLabel =>
        IsMobileDrawerOpen
            ? "Close navigation"
            : "Toggle navigation";

    private void ToggleNavigation()
    {
        IsMobileDrawerOpen = !IsMobileDrawerOpen;
        IsDesktopSidebarCollapsed =
            !IsDesktopSidebarCollapsed;
    }

    private void CloseMobileDrawer()
    {
        IsMobileDrawerOpen = false;
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            CloseMobileDrawer();
        }
    }
}