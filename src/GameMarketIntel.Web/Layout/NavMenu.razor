<nav class="@NavigationCssClass"
     aria-label="Application sections">

    <div class="navigation-section">
        <span class="navigation-section__label">
            Workspace
        </span>

        <NavLink class="navigation-link"
                 href=""
                 Match="NavLinkMatch.All"
                 title="Overview"
                 @onclick="NotifyNavigation">
            <svg viewBox="0 0 24 24"
                 aria-hidden="true">
                <path d="M4 10.5 12 4l8 6.5" />
                <path d="M6.5 9.5V20h11V9.5" />
                <path d="M9.5 20v-6h5v6" />
            </svg>

            <span class="navigation-link__label">
                Overview
            </span>
        </NavLink>

        <NavLink class="navigation-link"
                 href="games"
                 title="Comparable Games"
                 @onclick="NotifyNavigation">
            <svg viewBox="0 0 24 24"
                 aria-hidden="true">
                <path d="M8.5 8h7a5.5 5.5 0 0 1 5.2 7.3l-.8 2.2a2 2 0 0 1-3.3.8l-2.2-2.1H9.6l-2.2 2.1a2 2 0 0 1-3.3-.8l-.8-2.2A5.5 5.5 0 0 1 8.5 8Z" />
                <path d="M8 11v4M6 13h4M16.5 11.5h.01M18.5 14h.01" />
            </svg>

            <span class="navigation-link__label">
                Comparable Games
            </span>
        </NavLink>
    </div>

    <div class="navigation-section">
        <span class="navigation-section__label">
            Research data
        </span>

        <div class="navigation-link navigation-link--unavailable"
             aria-disabled="true"
             title="Genres — coming soon">
            <svg viewBox="0 0 24 24"
                 aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h10" />
            </svg>

            <span class="navigation-link__label">
                Genres
            </span>

            <span class="navigation-link__status">
                Soon
            </span>
        </div>

        <div class="navigation-link navigation-link--unavailable"
             aria-disabled="true"
             title="Platforms — coming soon">
            <svg viewBox="0 0 24 24"
                 aria-hidden="true">
                <rect x="3.5"
                      y="5"
                      width="17"
                      height="11"
                      rx="1.5" />
                <path d="M9 20h6M12 16v4" />
            </svg>

            <span class="navigation-link__label">
                Platforms
            </span>

            <span class="navigation-link__status">
                Soon
            </span>
        </div>

        <NavLink class="navigation-link"
                 href="sources"
                 title="Data Sources"
                 @onclick="NotifyNavigation">
            <svg viewBox="0 0 24 24"
                 aria-hidden="true">
                <ellipse cx="12"
                         cy="6"
                         rx="7.5"
                         ry="3" />
                <path d="M4.5 6v6c0 1.7 3.4 3 7.5 3s7.5-1.3 7.5-3V6" />
                <path d="M4.5 12v6c0 1.7 3.4 3 7.5 3s7.5-1.3 7.5-3v-6" />
            </svg>

            <span class="navigation-link__label">
                Data Sources
            </span>
        </NavLink>
    </div>
</nav>

@code {
    [Parameter]
    public bool IsCompact { get; set; }

    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private string NavigationCssClass =>
        IsCompact
            ? "application-navigation application-navigation--compact"
            : "application-navigation";

    private Task NotifyNavigation()
    {
        return OnNavigate.InvokeAsync();
    }
}