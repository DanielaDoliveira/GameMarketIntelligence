@page "/"


<PageTitle>Overview | GameMarketIntel</PageTitle>

<section class="page-heading">
    <span class="page-heading__eyebrow">Research workspace</span>

    <h1>Game market intelligence, organized for decisions</h1>

    <p class="page-heading__description">
        Explore comparable games and structured market data to support
        early product research.
    </p>
</section>


<section class="overview-grid" aria-label="Available research areas">
    <article class="overview-card overview-card--featured">
        <div class="overview-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
                <path d="M8.5 8h7a5.5 5.5 0 0 1 5.2 7.3l-.8 2.2a2 2 0 0 1-3.3.8l-2.2-2.1H9.6l-2.2 2.1a2 2 0 0 1-3.3-.8l-.8-2.2A5.5 5.5 0 0 1 8.5 8Z" />
                <path d="M8 11v4M6 13h4M16.5 11.5h.01M18.5 14h.01" />
            </svg>
        </div>
        
        <div class="overview-card__content">
            <span class="overview-card__status"> Available </span>

            <h2>Comparable Games</h2>

            <p>
                Search the current game dataset and explore results by
                name, genre, platform, and release year.
            </p>
        </div>
        
        <a class="button button--primary" href="/games">
            Explore comparable games

            <svg viewBox="0 0 24 24" aria-hidden="true"> <path d="M5 12h14M14 7l5 5-5 5" /> </svg>
        </a>

    </article>
    
    <article class="overview-card">
        <div class="overview-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
                <ellipse cx="12" cy="6" rx="7.5" ry="3" />
                <path d="M4.5 6v6c0 1.7 3.4 3 7.5 3s7.5-1.3 7.5-3V6" />
                <path d="M4.5 12v6c0 1.7 3.4 3 7.5 3s7.5-1.3 7.5-3v-6" />
            </svg>
        </div>
        
        <div class="overview-card__content">
            <span class="overview-card__status overview-card__status--secondary"> Foundation </span>

            <h2>Data Sources</h2>

            <p>
                Review the origin and reliability context of the sources
                used to build the research dataset.
            </p>
        </div>
        
        <a class="button button--secondary" href="/sources"> View data sources </a>
        
    </article>
    
    <article class="overview-card overview-card--unavailable"
             aria-disabled="true">
        <div class="overview-card__icon"
             aria-hidden="true">
            <svg viewBox="0 0 24 24">
                <path d="M4 19V9M10 19V5M16 19v-7M22 19H2" />
            </svg>
        </div>

        <div class="overview-card__content">
            <span class="overview-card__status overview-card__status--muted">
                Future milestone
            </span>

            <h2>Market Metrics</h2>

            <p>
                Commercial indicators, market evidence, and analytical
                comparisons will be introduced in a later milestone.
            </p>
        </div>
    </article>
    
</section>
